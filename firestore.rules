rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "asimkhankhan3236@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- Collections ---

    // 1. Users Profile
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) || isAdmin();
    }

    // 2. Patient Bookings
    match /bookings/{bookingId} {
      // Create a record
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      
      // List/Get records
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Manage records
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 3. System Connection
    match /test/{docId} {
      allow read: if isSignedIn();
    }
  }
}
