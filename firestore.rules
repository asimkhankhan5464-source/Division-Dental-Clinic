rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "asimmidadkhel@gmail.com"
      );
    }

    function isOwner(resourceData) {
      return isSignedIn() && (
        resourceData.userId == request.auth.uid || 
        resourceData.userEmail == request.auth.token.email
      );
    }

    // --- Collections ---

    // 1. Users Profile
    match /users/{uid} {
      allow read, write: if isSignedIn();
    }

    // 2. Patient Bookings
    match /bookings/{bookingId} {
      function isAdmin() {
        return isSignedIn() && (
          request.auth.token.email == 'asimmidadkhel@gmail.com'
        );
      }
      function isOwner(data) {
        return isSignedIn() && (data.userId == request.auth.uid || data.userEmail == request.auth.token.email);
      }

      allow create: if isSignedIn();
      allow list, get: if isOwner(resource.data) || isAdmin();
      allow update: if isOwner(resource.data) || isAdmin();
      allow delete: if isAdmin();
    }

    // 3. System Connection
    match /test/{docId} {
      allow read: if isSignedIn();
    }
  }
}
